# ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE
# ============================================================================

# MongoDB connection string
# Format: mongodb://[username:password@]host[:port]/database
# 
# Local development (no authentication):
MONGODB_URI=mongodb://localhost:27017/medeeka

# MongoDB Atlas (cloud) example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medeeka?retryWrites=true&w=majority

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret - used to sign authentication tokens
# ⚠️ IMPORTANT: Change this to a long random string!
# 
# Generate a secure secret:
# - Option 1: Use this command in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - Option 2: Visit: https://generate-random.org/ and generate 32-character hex
#
# NEVER commit the real JWT_SECRET to git!
JWT_SECRET=your_super_secret_key_change_this_in_production_12345

# ============================================================================
# SERVER
# ============================================================================

# Port number for the backend server
PORT=5000

# Environment type
# Options: development, production
NODE_ENV=development

# ============================================================================
# FRONTEND
# ============================================================================

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8000

# ============================================================================
# PRODUCTION SETTINGS (use when deploying)
# ============================================================================

# Uncomment these for production deployment:
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medeeka
# JWT_SECRET=your_production_secret_key_here
# PORT=5000 (or your cloud provider's port)
